# Required — get one at https://dev-dashboard.floelabs.xyz
FLOE_API_KEY=

# Optional — defaults to https://credit-api.floelabs.xyz
# FLOE_API_BASE_URL=

# Optional — HTTP server port (non-stdio mode only)
# MCP_PORT=3100

# Optional — bind address for HTTP mode (default: 127.0.0.1)
# MCP_HOST=0.0.0.0

# Optional — allow unauthenticated requests to use the server's FLOE_API_KEY (default: false)
# ALLOW_SHARED_KEY_FALLBACK=true
