{
  "name": "@floelabs/mcp-server",
  "version": "0.1.0",
  "description": "Floe DeFi lending protocol - MCP server for AI agents",
  "license": "MIT",
  "type": "module",
  "bin": {
    "floe-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "floe",
    "defi",
    "lending",
    "ai-agent",
    "model-context-protocol"
  ],
  "author": "Floe Labs",
  "repository": {
    "type": "git",
    "url": "https://github.com/Floe-Labs/floe-mcp-server"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "express": "^4.21.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
